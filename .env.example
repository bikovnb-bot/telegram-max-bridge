# Токен Telegram-бота (получить у @BotFather), бот должен быть добавлен в исходную группу
TELEGRAM_BOT_TOKEN=

# Старый формат одного маршрута (оставлен для обратной совместимости).
# Начиная с этой версии рекомендуется настраивать маршруты через веб-интерфейс
# (bridge/webui.py) — они сохраняются в переменную ROUTES ниже.
TELEGRAM_SOURCE_CHAT_ID=
MAX_TARGET_CHAT_ID=

# Несколько маршрутов пересылки: "tg_chat_id:max_chat_id:метка;tg_chat_id:max_chat_id:метка;..."
# Удобнее настраивать через веб-интерфейс, эта переменная перезаписывается им.
ROUTES=

# Номер телефона личного аккаунта MAX (используется только для запасного входа по SMS,
# основной сценарий — вход по QR через WebClient, номер для него не нужен)
MAX_PHONE=+7900xxxxxxx

# Папка для хранения сессии MAX (sqlite), лога и файла статуса
MAX_WORK_DIR=./max_session

# Веб-интерфейс (bridge/webui.py) для правки настроек и просмотра статуса/лога
WEBUI_USERNAME=admin
WEBUI_PASSWORD=
WEBUI_PORT=8765

# HTTP API для прямой пересылки в MAX в обход Telegram-группы (bridge/main.py, /forward).
# Нужен другим сервисам (например, вашему приложению), которые не могут
# доставить сообщение через саму Telegram-группу (боты не видят сообщения других ботов).
# Придумайте длинный случайный токен, например: openssl rand -hex 32
FORWARD_TOKEN=
FORWARD_PORT=8766

# Куда слать алерты о сбоях (id личного чата в Telegram с ботом-мостом, необязательно)
ALERT_CHAT_ID=
# Через сколько секунд простоя MAX слать алерт
ALERT_DISCONNECT_SECONDS=120

# Антифлуд: не больше RATE_LIMIT_MAX сообщений за RATE_LIMIT_WINDOW_SECONDS
# на один чат-источник (и на один чат-получатель для HTTP /forward), лишнее отбрасывается
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_SECONDS=60

# Пересылать ли ответы из MAX обратно в Telegram (для того же маршрута).
# Свои же пересланные ботом сообщения не эхуются обратно.
REVERSE_FORWARD_ENABLED=true

# Мониторинг диска/памяти сервера — шлёт алерт в ALERT_CHAT_ID при превышении порога
HOST_MONITOR_ENABLED=true
DISK_ALERT_PERCENT=90
MEM_ALERT_PERCENT=90
HOST_MONITOR_INTERVAL_SECONDS=300
